{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "baseUrl": "../../",
    "declaration": true,
    "declarationMap": true,
    "composite": true,
    "skipLibCheck": true,
    "paths": {
      "@openlinker/core/*": ["libs/core/src/*"],
      "@openlinker/shared": ["libs/shared/src/index.ts"],
      "@openlinker/shared/*": ["libs/shared/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"],
  "references": [
    { "path": "../shared" }
  ]
}

