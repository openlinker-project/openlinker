{
  "name": "@openlinker/core",
  "version": "0.1.0",
  "description": "OpenLinker Core Bounded Contexts",
  "private": true,
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    },
    "./integrations": {
      "types": "./dist/integrations/index.d.ts",
      "require": "./dist/integrations/index.js"
    },
    "./integrations/*": {
      "types": "./dist/integrations/*.d.ts",
      "require": "./dist/integrations/*.js"
    },
    "./identifier-mapping": {
      "types": "./dist/identifier-mapping/index.d.ts",
      "require": "./dist/identifier-mapping/index.js"
    },
    "./identifier-mapping/*": {
      "types": "./dist/identifier-mapping/*.d.ts",
      "require": "./dist/identifier-mapping/*.js"
    },
    "./orders": {
      "types": "./dist/orders/index.d.ts",
      "require": "./dist/orders/index.js"
    },
    "./products": {
      "types": "./dist/products/index.d.ts",
      "require": "./dist/products/index.js"
    },
    "./inventory": {
      "types": "./dist/inventory/index.d.ts",
      "require": "./dist/inventory/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "10.3.0",
    "@nestjs/typeorm": "10.0.2",
    "typeorm": "0.3.17"
  },
  "devDependencies": {
    "@types/jest": "29.5.12",
    "@types/node": "20.11.30",
    "@typescript-eslint/eslint-plugin": "7.3.1",
    "@typescript-eslint/parser": "7.3.1",
    "eslint": "8.57.0",
    "jest": "29.7.0",
    "ts-jest": "29.1.2",
    "typescript": "5.4.3"
  }
}

