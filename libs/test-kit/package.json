{
  "name": "@openlinker/test-kit",
  "version": "0.1.0",
  "description": "Integration-test harness for OpenLinker — Testcontainers (Postgres + Redis) + NestJS bootstrap factory for host apps and plugin authors (#600).",
  "license": "Apache-2.0",
  "private": true,
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "jest --config ./jest.config.js",
    "test:watch": "jest --watch --config ./jest.config.js",
    "test:cov": "jest --coverage --config ./jest.config.js",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@testcontainers/postgresql": "^10.0.0",
    "@testcontainers/redis": "^10.0.0",
    "express": "^4.0.0",
    "redis": "^4.0.0",
    "supertest": "^6.0.0",
    "typeorm": "^0.3.0"
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@testcontainers/postgresql": "10.13.2",
    "@testcontainers/redis": "10.13.2",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.12",
    "@types/node": "20.11.30",
    "@types/supertest": "6.0.2",
    "@typescript-eslint/eslint-plugin": "7.3.1",
    "@typescript-eslint/parser": "7.3.1",
    "eslint": "8.57.0",
    "express": "4.21.2",
    "jest": "29.7.0",
    "redis": "4.6.12",
    "supertest": "6.3.4",
    "ts-jest": "29.1.2",
    "typeorm": "0.3.17",
    "typescript": "5.4.3"
  }
}
