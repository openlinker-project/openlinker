{
  "name": "@openlinker/plugin-sdk",
  "version": "0.1.0",
  "description": "Plugin SDK for OpenLinker — AdapterPlugin contract + NestJS adapter for per-connection integration plugins (#593, #597).",
  "private": true,
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "jest --config ./jest.config.mjs",
    "test:watch": "jest --watch --config ./jest.config.mjs",
    "test:cov": "jest --coverage --config ./jest.config.mjs",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@openlinker/core": "workspace:*",
    "@openlinker/shared": "workspace:*"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/jest": "29.5.12",
    "@types/node": "20.11.30",
    "@typescript-eslint/eslint-plugin": "7.3.1",
    "@typescript-eslint/parser": "7.3.1",
    "eslint": "8.57.0",
    "jest": "29.7.0",
    "ts-jest": "29.1.2",
    "typescript": "5.4.3"
  }
}
