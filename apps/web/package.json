{
  "name": "@openlinker/web",
  "version": "0.1.0",
  "description": "OpenLinker frontend application",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint --ext .ts,.tsx src",
