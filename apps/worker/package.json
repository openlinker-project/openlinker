{
  "name": "@openlinker/worker",
  "version": "0.1.0",
  "description": "OpenLinker Worker Application",
  "license": "Apache-2.0",
  "author": "OpenLinker",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/apps/worker/src/main.js",
    "start:dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "start:watch": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/main.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:integration": "jest --config ./test/jest-integration.cjs",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "10.3.0",
    "@nestjs/core": "10.3.0",
    "@nestjs/config": "3.2.0",
    "@nestjs/typeorm": "10.0.2",
    "@openlinker/core": "workspace:*",
    "@openlinker/integrations-ai": "workspace:*",
    "@openlinker/integrations-allegro": "workspace:*",
    "@openlinker/integrations-inpost": "workspace:*",
    "@openlinker/integrations-prestashop": "workspace:*",
    "@openlinker/shared": "workspace:*",
    "pg": "8.11.3",
    "redis": "4.6.12",
    "reflect-metadata": "0.2.1",
    "rxjs": "7.8.1",
    "typeorm": "0.3.17"
  },
  "devDependencies": {
    "@jest/test-sequencer": "29.7.0",
    "@nestjs/testing": "10.3.0",
    "@testcontainers/postgresql": "^10.9.0",
    "@testcontainers/redis": "^10.9.0",
    "@types/jest": "29.5.12",
    "@types/node": "20.11.30",
    "@typescript-eslint/eslint-plugin": "7.3.1",
    "@typescript-eslint/parser": "7.3.1",
    "eslint": "8.57.0",
    "jest": "29.7.0",
    "ts-jest": "29.1.2",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.4.3"
  }
}
