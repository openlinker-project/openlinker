# OpenLinker E2E configuration
#
# Copy to `.env` (gitignored) and adjust for your stack. All values have
# localhost defaults baked into src/config/env.ts, so an unmodified local demo
# stack needs no .env at all.

# Web SPA base URL (Playwright `page` navigates here).
OL_WEB_URL=http://localhost:8090

# REST API base ORIGIN (no /v1 suffix — the client appends the version segment).
OL_API_URL=http://localhost:3000

# Admin operator credentials used by both auth paths (browser storageState +
# node API bearer login).
OL_ADMIN_USER=admin
OL_ADMIN_PASS=admin

# Optional: pin a specific order for the (follow-up) post-purchase segments.
# Leave unset for the S1-S4 operator-setup path, which does not need it.
E2E_ORDER_ID=
