# ─────────────────────────────────────────────────────────────────────────────
# OpenLinker API — example environment
# Copy to .env.local and adjust for your setup:
#   cp apps/api/.env.example apps/api/.env.local
# Values below match the default dev stack (pnpm dev:stack:up).
# ─────────────────────────────────────────────────────────────────────────────

# --- Runtime ------------------------------------------------------------------
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# --- JWT auth -----------------------------------------------------------------
# REQUIRED. Change for any non-local environment.
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=1d

# --- PostgreSQL (matches dev stack) -------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=openlinker

# --- Redis (matches dev stack) ------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- Credentials store --------------------------------------------------------
# Reference key used by the in-memory credentials resolver in dev/tests.
CREDENTIALS_TEST_CREDENTIALS_REF=BXCJUVRP6K6ZBGXF9YSLL47Q48INUS3W

# --- Webhook secrets ----------------------------------------------------------
# Pattern: OPENLINKER_WEBHOOK_SECRET__<PROVIDER>__<CONNECTION_ID>
# One entry per connection that receives webhooks. Provider + connectionId are
# uppercased. Example (PrestaShop, connection 59F4129E-...):
OPENLINKER_WEBHOOK_SECRET__PRESTASHOP__59F4129E-A827-4650-B69B-FC2302B9ECB7=test-secret-key-12345

# --- Schedulers: Allegro orders poll ------------------------------------------
ALLEGRO_POLL_SCHEDULER_ENABLED=false
ALLEGRO_POLL_INTERVAL_CRON=*/5 * * * *

# --- Schedulers: Allegro offers sync ------------------------------------------
ALLEGRO_OFFERS_SYNC_SCHEDULER_ENABLED=true
ALLEGRO_OFFERS_SYNC_INTERVAL_CRON=*/1 * * * *
ALLEGRO_OFFERS_SYNC_PAGE_LIMIT=100

# --- Order sync routing -------------------------------------------------------
# Connection ID of the destination platform (e.g., PrestaShop) that orders
# ingested from marketplaces are written to. Leave unset until you have created
# the destination connection, then fill in its UUID.
# ORDER_SYNC_DESTINATION_CONNECTION_ID=

# --- Customer identity --------------------------------------------------------
# external_only | email_fallback  (see docs/architecture-overview.md)
OL_CUSTOMER_IDENTITY_MODE=email_fallback

# --- PII storage --------------------------------------------------------------
# true  = store raw PII (email, names, addresses)
# false = store only hashes (emailHash always persisted)
OL_STORE_PII=true

# REQUIRED. Org-level salt for deterministic PII hashing.
# WARNING: changing this breaks existing hash lookups.
OL_PII_HASH_SALT=your-org-level-salt-change-in-production
