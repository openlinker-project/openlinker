# Application
NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=openlinker

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=1d

# PrestaShop Configuration
# These settings will be used by future PrestaShop adapters
# Note: Connection-specific config will be stored in Connection entity
PRESTASHOP_BASE_URL=http://localhost:8080
PRESTASHOP_API_KEY=your-prestashop-webservice-api-key
PRESTASHOP_WEBHOOK_SECRET=your-webhook-secret-optional

# Credentials for Connections
# Format: CREDENTIALS_{credentialsRef} where credentialsRef is from your Connection entity
# For PrestaShop, you can use either format:
# Option 1: Plain string (simpler, auto-wrapped to JSON)
# CREDENTIALS_TEST_CREDENTIALS_REF=your-prestashop-webservice-api-key
# Option 2: JSON object (required for multi-field credentials like Allegro)
# CREDENTIALS_TEST_CREDENTIALS_REF={"webserviceApiKey":"your-prestashop-webservice-api-key"}


