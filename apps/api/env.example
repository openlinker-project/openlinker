# Application
NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=openlinker

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=1d

# PrestaShop Configuration
# These settings will be used by future PrestaShop adapters
# Note: Connection-specific config will be stored in Connection entity
PRESTASHOP_BASE_URL=http://localhost:8080
PRESTASHOP_API_KEY=your-prestashop-webservice-api-key
PRESTASHOP_WEBHOOK_SECRET=your-webhook-secret-optional

# Credentials for Connections
# Format: CREDENTIALS_{credentialsRef} where credentialsRef is from your Connection entity
# For PrestaShop, you can use either format:
# Option 1: Plain string (simpler, auto-wrapped to JSON)
# CREDENTIALS_TEST_CREDENTIALS_REF=your-prestashop-webservice-api-key
# Option 2: JSON object (required for multi-field credentials like Allegro)
# CREDENTIALS_TEST_CREDENTIALS_REF={"webserviceApiKey":"your-prestashop-webservice-api-key"}

# Scheduler Configuration
# Allegro Orders Poll Scheduler
# Enable/disable the Allegro orders poll scheduler (default: true)
ALLEGRO_POLL_SCHEDULER_ENABLED=true
# Cron expression for Allegro orders poll interval (default: every 5 minutes)
# Examples:
#   */5 * * * *   - Every 5 minutes
#   */10 * * * *  - Every 10 minutes
#   0 * * * *     - Every hour
ALLEGRO_POLL_INTERVAL_CRON=*/5 * * * *

# Customer Identity & PII Configuration
# Customer identity resolution mode (default: email_fallback)
# - external_only: Only use external buyer ID mapping (no email fallback)
# - email_fallback: Use email hash fallback if external mapping not found (may merge customers with shared emails)
OL_CUSTOMER_IDENTITY_MODE=email_fallback

# PII Storage Configuration
# Whether to store raw PII data (email, names, addresses) (default: true)
# When false, only hashes are stored (emailHash, addressHash)
# emailHash is always persisted regardless of this setting
OL_STORE_PII=true

# Organization-level salt for PII hashing (REQUIRED)
# Used for deterministic hashing of emails and addresses
# Must be set to a secure, organization-specific value
# WARNING: Changing this value will break existing hash lookups (requires data migration)
OL_PII_HASH_SALT=your-org-level-salt-change-in-production


