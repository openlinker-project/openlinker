# Application
NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=openlinker

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=1d

# PrestaShop Configuration
# These settings will be used by future PrestaShop adapters
# Note: Connection-specific config will be stored in Connection entity
PRESTASHOP_BASE_URL=http://localhost:8080
PRESTASHOP_API_KEY=your-prestashop-webservice-api-key
PRESTASHOP_WEBHOOK_SECRET=your-webhook-secret-optional


