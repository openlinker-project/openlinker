{
  "name": "@openlinker/api",
  "version": "0.1.0",
  "description": "OpenLinker API Application",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "pnpm -w run build:api",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "pnpm -w run start:dev:api",
    "start:dev": "pnpm -w run start:dev:api",
    "start:debug": "pnpm -w run start:dev:api -- --debug",
    "start:prod": "pnpm -w run start:prod:api",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:integration": "jest --config ./test/jest-integration.js",
    "type-check": "tsc -p tsconfig.type-check.json",
    "migration:generate": "bash scripts/migration-generate.sh",
    "migration:run": "NODE_OPTIONS='-r ts-node/register -r tsconfig-paths/register' bash node_modules/.bin/typeorm migration:run -d src/database/data-source.ts",
    "migration:revert": "NODE_OPTIONS='-r ts-node/register -r tsconfig-paths/register' bash node_modules/.bin/typeorm migration:revert -d src/database/data-source.ts",
    "migration:show": "NODE_OPTIONS='-r ts-node/register -r tsconfig-paths/register' bash node_modules/.bin/typeorm migration:show -d src/database/data-source.ts"
  },
  "dependencies": {
    "@nestjs/common": "10.3.0",
    "@nestjs/core": "10.3.0",
    "@nestjs/platform-express": "10.3.0",
    "@nestjs/config": "3.2.0",
    "@nestjs/axios": "3.0.2",
    "@nestjs/typeorm": "10.0.2",
    "@nestjs/jwt": "10.2.0",
    "@nestjs/passport": "10.0.3",
    "@nestjs/schedule": "4.0.0",
    "@nestjs/swagger": "^7.3.0",
    "@openlinker/core": "workspace:*",
    "@openlinker/integrations-allegro": "workspace:*",
    "@openlinker/integrations-prestashop": "workspace:*",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "pg": "8.11.3",
    "redis": "4.6.12",
    "reflect-metadata": "0.2.1",
    "rxjs": "7.8.1",
    "typeorm": "0.3.17"
  },
  "devDependencies": {
    "@nestjs/cli": "10.3.0",
    "@nestjs/schematics": "10.1.0",
    "@nestjs/testing": "10.3.0",
    "@testcontainers/postgresql": "^10.9.0",
    "@testcontainers/redis": "^10.9.0",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.12",
    "@types/node": "20.11.30",
    "@types/passport-jwt": "4.0.1",
    "@types/supertest": "6.0.2",
    "@typescript-eslint/eslint-plugin": "7.3.1",
    "@typescript-eslint/parser": "7.3.1",
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "jest": "29.7.0",
    "prettier": "3.2.5",
    "source-map-support": "0.5.21",
    "supertest": "7.0.0",
    "ts-jest": "29.1.2",
    "ts-loader": "9.5.1",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.4.3"
  }
}

