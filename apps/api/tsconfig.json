{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "declaration": false,
    "target": "ES2022",
    "outDir": "./dist",
    "baseUrl": "./",
    "allowJs": true,
    "paths": {
      "@openlinker/api/*": ["./src/*"],
      "@openlinker/core/*": ["../../libs/core/src/*"],
      "@openlinker/shared/*": ["../../libs/shared/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test", "../../libs/**/*"]
}

